# ── Server ──────────────────────────────────────────────────
PORT=3000

# The public URL of your server (used in verification email links)
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────
# Change this to a long random secret before deploying!
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# ── Email (SMTP) ──────────────────────────────────────────────
# Option 1 — Gmail (easiest for testing)
#   1. Enable 2-Step Verification on your Google account
#   2. Generate an App Password: myaccount.google.com → Security → App Passwords
#   3. Use your Gmail address and the App Password below
#
# Option 2 — Any SMTP provider (SendGrid, Mailgun, etc.)
# qbab gddi nhty zrbb
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=michael.andoni7@gmail.com
SMTP_PASS=qbabgddinhtyzrbb
EMAIL_FROM="Cat Lobby michael.andoni7@gmail.com"

# ── Database ──────────────────────────────────────────────────
# SQLite file path — relative to project root
# The file is created automatically on first run
DB_PATH=./catlobby.db
